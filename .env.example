# Admiral Backend Configuration

# Server
PORT=3001
NODE_ENV=production

# Database
DB_PATH=./admiral.db
FABRICKEN_DB_PATH=/root/.openclaw/workspace/crm/fabricken.db

# Frontend
FRONTEND_URL=https://admiral.fabricken.se

# JWT - CRITICAL: Must be set in production!
# Generate: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_STRING

# Meta Ads API
META_APP_SECRET=your-meta-app-secret
WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Viktor Notifications (OpenClaw sessions)
VIKTOR_SESSION_ID=viktor-ekonomi-session-id
OPENCLAW_API_URL=http://localhost:3000

# Optional: Netlify deployment
NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_AUTH_TOKEN=your-netlify-auth-token
